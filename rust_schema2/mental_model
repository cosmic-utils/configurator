

impl RustSchemaTrait for A {

    inline = false,

    
    fn schema(generator: &mut Generator) -> RustSchema {


        RustSchema {
            kind: RustSchemaKind::Struct("A", {
                x: i32::schema(generator),
                y: Option<Box<B>>::schema(generator)
            })
        }

    }

}


impl<T: JsonSchema> RustSchemaTrait for Option<T> {

    inline = true,
    
    fn schema(generator: &mut Generator) -> RustSchema {
        RustSchema {
            kind: RustSchemaKind::Option(T::schema(generator))
        }
    }
}

impl<T: JsonSchema> RustSchemaTrait for Box<T> {

    inline = true,
    
    fn schema(generator: &mut Generator) -> RustSchema {
        T::schema(generator)
    }
}


impl RustSchemaTrait for A {

    inline = false,

    
    fn schema(generator: &mut Generator) -> RustSchema {

        RustSchema {
            kind: RustSchemaKind::Struct("B", {
                x: i32::schema(generator),
            })
        }
    }

}

fn generate<T: RustSchemaTrait>() -> RustSchemaRoot {
    let mut g = Generator::new();
}